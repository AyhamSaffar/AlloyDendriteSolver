{
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: gcc.exe build active file", 
			"command": "/usr/bin/g++", // "sudo apt install g++" required
			"args": [
				"${file}",
				"-std=c++23",
				"-ggdb",
				"-pedantic-errors",
				"-Wall",
				"-Weffc++",
				"-Wextra",
				"-Wconversion",
				"-Wsign-conversion",
				"-Wshadow",
				"-Werror",
			  	"-o",
			  	"${fileDirname}\\${fileBasenameNoExtension}",
			],
	 		"options": {"cwd": "${fileDirname}"},
			"problemMatcher": ["$gcc"],
	  		"group": {
				"kind": "build",
				"isDefault": true,
			}
		}
	],
	"version": "2.0.0",
}
